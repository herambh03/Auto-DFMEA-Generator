import React, { useState, useRef, useEffect } from 'react';
import { UploadCloud, File, AlertCircle, CheckCircle2, Settings, Download, Play, RefreshCw, FileText, ChevronRight } from 'lucide-react';

// --- API Configuration ---
const apiKey = ""; // The execution environment provides the key at runtime.

// --- Helper: Exponential Backoff API Call ---
const fetchWithRetry = async (url, options, maxRetries = 5) => {
  let delay = 1000;
  for (let i = 0; i < maxRetries; i++) {
    try {
      const response = await fetch(url, options);
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return await response.json();
    } catch (error) {
      if (i === maxRetries - 1) throw error;
      await new Promise(resolve => setTimeout(resolve, delay));
      delay *= 2;
    }
  }
};

export default function App() {
  const [stepFile, setStepFile] = useState(null);
  const [systemText, setSystemText] = useState('');
  const [isGenerating, setIsGenerating] = useState(false);
  const [loadingStatus, setLoadingStatus] = useState('');
  const [dfmeaData, setDfmeaData] = useState(null);
  const [error, setError] = useState('');
  const fileInputRef = useRef(null);

  // Example data for easy testing
  const loadExample = () => {
    setSystemText("The component is an aluminum engine mounting bracket. It connects the engine block to the chassis subframe. It must isolate high-frequency engine vibrations while absorbing low-frequency torque loads during hard acceleration. It is exposed to under-hood temperatures (up to 120C), road salt, and potential fluid leaks (oil/coolant).");
    // Mocking a file for the example
    const mockFile = new File([""], "Engine_Mount_Bracket_v3.step", { type: "model/step" });
    setStepFile(mockFile);
    setDfmeaData(null);
    setError('');
  };

  const handleFileChange = (e) => {
    const file = e.target.files[0];
    if (file && (file.name.toLowerCase().endsWith('.step') || file.name.toLowerCase().endsWith('.stp'))) {
      setStepFile(file);
      setError('');
    } else if (file) {
      setError('Please upload a valid .STEP or .STP file.');
    }
  };

  const handleDragOver = (e) => {
    e.preventDefault();
  };

  const handleDrop = (e) => {
    e.preventDefault();
    const file = e.dataTransfer.files[0];
    if (file && (file.name.toLowerCase().endsWith('.step') || file.name.toLowerCase().endsWith('.stp'))) {
      setStepFile(file);
      setError('');
    } else if (file) {
      setError('Please upload a valid .STEP or .STP file.');
    }
  };

  const generateDFMEA = async () => {
    if (!stepFile && !systemText) {
      setError("Please provide both a STEP file and system interaction text.");
      return;
    }

    setIsGenerating(true);
    setError('');
    setDfmeaData(null);

    try {
      // 1. Simulate STEP Parsing
      setLoadingStatus('Parsing B-Rep Geometry & Metadata from STEP...');
      await new Promise(r => setTimeout(r, 1500)); 
      
      // 2. Simulate Entity Alignment
      setLoadingStatus('Aligning System Text with CAD Entities...');
      await new Promise(r => setTimeout(r, 1500));

      // 3. API Call for AI Generation
      setLoadingStatus('Running Failure Mode Heuristics... (Generating 20+ items)');
      
      const prompt = `
        You are an expert Automotive Reliability Engineer performing an exhaustive Design Failure Mode and Effects Analysis (DFMEA) strictly following the AIAG & VDA FMEA Handbook methodology required for IATF 16949 compliance.
        
        CAD Part Context (Simulated from filename): ${stepFile ? stepFile.name : 'Unknown Part'}
        System Interaction & Functional Context: ${systemText}
        
        CRITICAL INSTRUCTION: Break the component down into sub-features (System Elements).
        For EACH sub-feature, identify distinct failure mechanisms.
        
        You MUST generate a highly detailed table with AT LEAST 15-20 distinct failure modes to match professional automotive engineering rigor.
        
        Format Requirements (AIAG-VDA 7-Step approach):
        1. System Element (e.g., Mounting Hole)
        2. Function (e.g., Provide clamping force)
        3. Failure Effect (FE)
        4. Severity (S) (1-10)
        5. Failure Mode (FM)
        6. Failure Cause (FC)
        7. Current Prevention Control (PC)
        8. Occurrence (O) (1-10)
        9. Current Detection Control (DC)
        10. Detection (D) (1-10)
        11. Action Priority (AP): Evaluate as "High", "Medium", or "Low" based on standard AIAG-VDA S-O-D matrices (e.g. High severity and high occurrence = High AP).
        12. Recommended Action (Optimization)
      `;

      const schema = {
        type: "ARRAY",
        description: "List of IATF compliant AIAG-VDA DFMEA rows",
        items: {
          type: "OBJECT",
          properties: {
            systemElement: { type: "STRING", description: "1. System Element / Item" },
            function: { type: "STRING", description: "2. Function of the Element" },
            failureEffect: { type: "STRING", description: "3. Failure Effect (FE)" },
            severity: { type: "INTEGER", description: "Severity Score (1-10)" },
            failureMode: { type: "STRING", description: "4. Failure Mode (FM)" },
            failureCause: { type: "STRING", description: "5. Failure Cause (FC)" },
            preventionControl: { type: "STRING", description: "Current Prevention Control (PC)" },
            occurrence: { type: "INTEGER", description: "Occurrence Score (1-10)" },
            detectionControl: { type: "STRING", description: "Current Detection Control (DC)" },
            detection: { type: "INTEGER", description: "Detection Score (1-10)" },
            actionPriority: { type: "STRING", description: "Action Priority (AP) - High, Medium, or Low" },
            recommendedAction: { type: "STRING", description: "Optimization / Recommended Action" }
          },
          required: ["systemElement", "function", "failureEffect", "severity", "failureMode", "failureCause", "preventionControl", "occurrence", "detectionControl", "detection", "actionPriority", "recommendedAction"]
        }
      };

      const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
      const payload = {
        contents: [{ parts: [{ text: prompt }] }],
        systemInstruction: { parts: [{ text: "You are a specialized AI agent generating structured DFMEA data." }] },
        generationConfig: {
          responseMimeType: "application/json",
          responseSchema: schema
        }
      };

      const result = await fetchWithRetry(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const generatedText = result.candidates?.[0]?.content?.parts?.[0]?.text;
      if (!generatedText) throw new Error("Failed to generate content.");
      
      const parsedData = JSON.parse(generatedText);

      setLoadingStatus('Formatting IATF Compliant Output...');
      await new Promise(r => setTimeout(r, 800));

      setDfmeaData(parsedData);
      
    } catch (err) {
      console.error(err);
      setError("An error occurred during DFMEA generation. Please try again.");
    } finally {
      setIsGenerating(false);
      setLoadingStatus('');
    }
  };

  const exportToCSV = () => {
    if (!dfmeaData) return;
    
    const headers = ['System Element', 'Function', 'Failure Effect', 'S', 'Failure Mode', 'Failure Cause', 'Prevention Controls', 'O', 'Detection Controls', 'D', 'AP', 'Recommended Action'];
    
    const csvRows = [
      headers.join(','), // Header row
      ...dfmeaData.map(row => [
        `"${row.systemElement.replace(/"/g, '""')}"`,
        `"${row.function.replace(/"/g, '""')}"`,
        `"${row.failureEffect.replace(/"/g, '""')}"`,
        row.severity,
        `"${row.failureMode.replace(/"/g, '""')}"`,
        `"${row.failureCause.replace(/"/g, '""')}"`,
        `"${row.preventionControl.replace(/"/g, '""')}"`,
        row.occurrence,
        `"${row.detectionControl.replace(/"/g, '""')}"`,
        row.detection,
        `"${row.actionPriority}"`,
        `"${row.recommendedAction.replace(/"/g, '""')}"`
      ].join(','))
    ];

    const csvContent = "data:text/csv;charset=utf-8," + csvRows.join('\n');
    const encodedUri = encodeURI(csvContent);
    const link = document.createElement("a");
    link.setAttribute("href", encodedUri);
    link.setAttribute("download", `DFMEA_${stepFile?.name?.split('.')[0] || 'Generated'}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  const getAPColor = (ap) => {
    const priority = ap.toLowerCase();
    if (priority.includes('high')) return 'bg-red-100 text-red-800 font-bold border border-red-200';
    if (priority.includes('medium')) return 'bg-yellow-100 text-yellow-800 font-semibold border border-yellow-200';
    return 'bg-green-100 text-green-800 border border-green-200';
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans p-4 md:p-8">
      
      {/* Header */}
      <header className="max-w-6xl mx-auto mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
          <h1 className="text-3xl font-bold text-slate-900 flex items-center gap-3">
            <Settings className="w-8 h-8 text-blue-600" />
            Auto-DFMEA <span className="text-blue-600 font-light">Nexus</span>
          </h1>
          <p className="text-slate-500 mt-1">Transform CAD data and system text into actionable risk analysis.</p>
        </div>
        <button 
          onClick={loadExample}
          className="text-sm px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 rounded-md transition-colors font-medium flex items-center gap-2"
        >
          <FileText className="w-4 h-4" /> Load Example Data
        </button>
      </header>

      <main className="max-w-6xl mx-auto space-y-6">
        
        {/* Input Section */}
        <div className="grid md:grid-cols-2 gap-6">
          
          {/* STEP File Upload */}
          <div className="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
            <h2 className="text-lg font-semibold mb-4 flex items-center gap-2">
              <span className="bg-blue-100 text-blue-700 w-6 h-6 rounded-full flex items-center justify-center text-sm">1</span>
              Upload STEP File
            </h2>
            <div 
              onDragOver={handleDragOver}
              onDrop={handleDrop}
              className={`border-2 border-dashed rounded-lg p-8 flex flex-col items-center justify-center text-center transition-colors
                ${stepFile ? 'border-green-400 bg-green-50' : 'border-slate-300 hover:border-blue-400 bg-slate-50'}
              `}
            >
              <input 
                type="file" 
                ref={fileInputRef} 
                onChange={handleFileChange} 
                accept=".step,.stp" 
                className="hidden" 
              />
              
              {stepFile ? (
                <>
                  <CheckCircle2 className="w-12 h-12 text-green-500 mb-3" />
                  <p className="font-medium text-slate-900">{stepFile.name}</p>
                  <p className="text-xs text-slate-500 mt-1">{(stepFile.size / 1024 / 1024).toFixed(2)} MB</p>
                  <button 
                    onClick={() => setStepFile(null)} 
                    className="mt-4 text-sm text-red-500 hover:underline"
                  >
                    Remove file
                  </button>
                </>
              ) : (
                <>
                  <UploadCloud className="w-12 h-12 text-slate-400 mb-3" />
                  <p className="text-sm text-slate-600 mb-2">Drag and drop your CAD file here</p>
                  <p className="text-xs text-slate-400 mb-4">Supported formats: .STEP, .STP</p>
                  <button 
                    onClick={() => fileInputRef.current?.click()}
                    className="px-4 py-2 bg-white border border-slate-300 rounded-md text-sm font-medium hover:bg-slate-50"
                  >
                    Browse Files
                  </button>
                </>
              )}
            </div>
          </div>

          {/* System Interaction Text */}
          <div className="bg-white p-6 rounded-xl shadow-sm border border-slate-200 flex flex-col">
            <h2 className="text-lg font-semibold mb-4 flex items-center gap-2">
              <span className="bg-blue-100 text-blue-700 w-6 h-6 rounded-full flex items-center justify-center text-sm">2</span>
              System Interaction Context
            </h2>
            <p className="text-sm text-slate-500 mb-3">Describe the part's function, loads, interfaces, and operating environment.</p>
            <textarea 
              value={systemText}
              onChange={(e) => setSystemText(e.target.value)}
              placeholder="e.g., This bracket connects the sensor housing to the main chassis. It experiences high-frequency vibrations and must maintain alignment within 0.1mm..."
              className="flex-1 w-full p-3 border border-slate-300 rounded-lg resize-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm"
            ></textarea>
          </div>

        </div>

        {/* Action Bar */}
        <div className="flex flex-col sm:flex-row items-center justify-between gap-4 bg-white p-4 rounded-xl shadow-sm border border-slate-200">
          <div className="flex-1">
             {error && (
               <div className="flex items-center gap-2 text-red-600 text-sm bg-red-50 px-3 py-2 rounded-md">
                 <AlertCircle className="w-4 h-4" /> {error}
               </div>
             )}
          </div>
          <button 
            onClick={generateDFMEA}
            disabled={isGenerating || (!stepFile && !systemText)}
            className={`px-6 py-3 rounded-lg font-semibold flex items-center gap-2 transition-all shadow-sm
              ${isGenerating || (!stepFile && !systemText) 
                ? 'bg-slate-300 text-slate-500 cursor-not-allowed' 
                : 'bg-blue-600 hover:bg-blue-700 text-white hover:shadow-md'
              }
            `}
          >
            {isGenerating ? (
              <><RefreshCw className="w-5 h-5 animate-spin" /> Generating...</>
            ) : (
              <><Play className="w-5 h-5 fill-current" /> Generate DFMEA</>
            )}
          </button>
        </div>

        {/* Loading State Overlay / Inline */}
        {isGenerating && (
          <div className="bg-blue-50 border border-blue-100 rounded-xl p-6 flex flex-col items-center justify-center py-12">
             <div className="relative w-16 h-16 mb-4">
                <div className="absolute inset-0 border-4 border-blue-200 rounded-full"></div>
                <div className="absolute inset-0 border-4 border-blue-600 rounded-full border-t-transparent animate-spin"></div>
             </div>
             <p className="text-lg font-medium text-blue-900 mb-2">Analyzing Design Data</p>
             <p className="text-sm text-blue-600 flex items-center gap-2">
                <ChevronRight className="w-4 h-4" /> {loadingStatus}
             </p>
          </div>
        )}

        {/* Results Section */}
        {dfmeaData && !isGenerating && (
          <div className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden animate-in fade-in slide-in-from-bottom-4 duration-500">
            <div className="p-4 border-b border-slate-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-slate-50">
              <div>
                <h2 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                  <File className="w-5 h-5 text-blue-600" />
                  Generated DFMEA Analysis
                </h2>
                <p className="text-xs text-slate-500 mt-1">
                  Based on: {stepFile?.name} + Provided Context
                </p>
              </div>
              <button 
                onClick={exportToCSV}
                className="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-md text-sm font-medium flex items-center gap-2 transition-colors shadow-sm"
              >
                <Download className="w-4 h-4" /> Export CSV
              </button>
            </div>

            <div className="overflow-x-auto">
              <table className="w-full text-sm text-left whitespace-nowrap md:whitespace-normal">
                <thead className="text-xs text-slate-700 uppercase bg-slate-100 border-b border-slate-200">
                  <tr>
                    <th className="px-4 py-3 min-w-[120px]">System Element</th>
                    <th className="px-4 py-3 min-w-[150px]">Function</th>
                    <th className="px-4 py-3 min-w-[180px]">Failure Effect</th>
                    <th className="px-2 py-3 text-center" title="Severity">S</th>
                    <th className="px-4 py-3 min-w-[180px]">Failure Mode</th>
                    <th className="px-4 py-3 min-w-[180px]">Failure Cause</th>
                    <th className="px-4 py-3 min-w-[150px]">Prevention Control</th>
                    <th className="px-2 py-3 text-center" title="Occurrence">O</th>
                    <th className="px-4 py-3 min-w-[150px]">Detection Control</th>
                    <th className="px-2 py-3 text-center" title="Detection">D</th>
                    <th className="px-3 py-3 text-center">AP</th>
                    <th className="px-4 py-3 min-w-[200px]">Optimization Action</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-slate-100">
                  {dfmeaData.map((row, idx) => (
                    <tr key={idx} className="hover:bg-slate-50 transition-colors">
                      <td className="px-4 py-3 align-top font-medium text-slate-900">{row.systemElement}</td>
                      <td className="px-4 py-3 align-top text-slate-700">{row.function}</td>
                      <td className="px-4 py-3 align-top text-slate-600">{row.failureEffect}</td>
                      <td className="px-2 py-3 align-top text-center font-bold bg-red-50">{row.severity}</td>
                      <td className="px-4 py-3 align-top text-red-700 font-medium">{row.failureMode}</td>
                      <td className="px-4 py-3 align-top text-slate-600">{row.failureCause}</td>
                      <td className="px-4 py-3 align-top text-slate-600 text-xs">{row.preventionControl}</td>
                      <td className="px-2 py-3 align-top text-center font-bold bg-yellow-50">{row.occurrence}</td>
                      <td className="px-4 py-3 align-top text-slate-600 text-xs">{row.detectionControl}</td>
                      <td className="px-2 py-3 align-top text-center font-bold bg-green-50">{row.detection}</td>
                      <td className="px-3 py-3 align-top text-center">
                        <span className={`px-2 py-1 rounded text-xs ${getAPColor(row.actionPriority)}`}>
                          {row.actionPriority.toUpperCase()}
                        </span>
                      </td>
                      <td className="px-4 py-3 align-top text-slate-600 italic text-xs">{row.recommendedAction}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

      </main>
    </div>
  );
}
